# === BUAA SSO 登录凭据 ===
BUAA_USERNAME=your_student_id
BUAA_PASSWORD=your_password

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# === Email SMTP (Gmail) ===
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password
# 可选：覆盖不同类型邮件的发件人地址（用于 Brevo 多 Sender）
SMTP_FROM=notify@example.com
SMTP_FROM_VERIFY=verify@example.com
SMTP_FROM_LOGIN=verify@example.com
SMTP_FROM_NOTIFY=notify@example.com
SMTP_FROM_REMINDER=notify@example.com
# 可选：按邮件类型拆分 SMTP 通道（不使用 Brevo 时可用）
# 验证/登录邮件通道（例如 QQ SMTP）
SMTP_VERIFY_SERVER=smtp.qq.com
SMTP_VERIFY_PORT=465
SMTP_VERIFY_USE_TLS=false
SMTP_VERIFY_USERNAME=verify@qq.com
SMTP_VERIFY_PASSWORD=qq_smtp_auth_code
# 通知/提醒邮件通道（例如 Gmail SMTP）
SMTP_NOTIFY_SERVER=smtp.gmail.com
SMTP_NOTIFY_PORT=587
SMTP_NOTIFY_USE_TLS=true
SMTP_NOTIFY_USERNAME=notify@gmail.com
SMTP_NOTIFY_PASSWORD=gmail_app_password

# === Web Console ===
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_SECRET_KEY=change_this_to_random_string
# 对外访问基址（用于验证/登录邮件链接生成，务必填公网域名）
APP_PUBLIC_BASE_URL=https://buaayqq.eu.cc

# === Scheduler ===
SCRAPE_INTERVAL_MINUTES=10
